# Shared with Aurora — must match auroraBackend/.env
MONGO_URI=mongodb://user:pass@host:27017/?ssl=true
MONGO_DB_NAME=test
JWT_SECRET=your_aurora_jwt_secret

# Groq LLM (required for chat)
GROQ_API_KEY=your_groq_api_key_here

# Optional: disable nightly forecasting job in local dev
FORECASTING_SCHEDULER=0

# AI service port (Aurora embeds http://localhost:8000)
PORT=8000

# Orders tab: read Aurora-synced Mongo orders (db) or live SP-API (sp_api)
AURORA_ORDERS_SOURCE=db
# DB-first for orders, inventory, campaigns; SP-API when required data is missing
AURORA_DATA_SOURCE=db
